{
  "name": "clip",
  "private": true,
  "version": "1.1.0",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "biome check . --error-on-warnings",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --coverage",
    "test:e2e": "bun run scripts/run-e2e.ts",
    "test:integration": "echo 'No integration tests yet'",
    "quality:full": "bun run lint && bun run typecheck && bun run test:unit && bun run test:e2e && bun run lint:secrets && bun run lint:deps",
    "lint:secrets": "gitleaks detect --source . --verbose",
    "lint:deps": "osv-scanner --lockfile bun.lock",
    "prepare": "git config core.hooksPath scripts/hooks"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@nocoo/base-cli": "^0.3.0",
    "@types/bun": "1.3.14",
    "@vitest/coverage-v8": "4.1.10",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "overrides": {
    "devalue": ">=5.8.1",
    "esbuild": ">=0.28.1",
    "js-yaml": "^4.2.0",
    "vite": "^8.0.13"
  }
}
