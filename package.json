{
  "name": "clip",
  "private": true,
  "version": "0.0.2",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "biome check . --error-on-warnings",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --coverage",
    "test:integration": "echo 'No integration tests yet'",
    "lint:secrets": "gitleaks detect --source . --verbose",
    "lint:deps": "osv-scanner --lockfile bun.lock",
    "prepare": "git config core.hooksPath scripts/hooks"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/bun": "1.3.14",
    "@vitest/coverage-v8": "4.1.9",
    "typescript": "^6.0.2",
    "vitest": "4.1.9"
  },
  "overrides": {
    "devalue": ">=5.8.1",
    "esbuild": ">=0.28.1",
    "js-yaml": ">=4.2.0",
    "vite": "7.3.5"
  }
}
