{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on"
        }
      }
    }
  },
  "files": {
    "includes": [
      "**/*.ts",
      "**/*.json",
      "**/*.astro",
      "!!**/node_modules",
      "!!**/dist",
      "!!**/.clip-output",
      "!!**/.astro"
    ]
  }
}
