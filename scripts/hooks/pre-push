#!/bin/bash
set -e
echo "🔍 Running pre-push checks..."

# L2 — End-to-end behavior proofs (real spawn, real HTTP)
bun run test:e2e

# G2 — Security scanning (hard-fail; bypassing is the wrong incentive)
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "❌ gitleaks not installed. Install via: brew install gitleaks" >&2
  exit 1
fi
gitleaks detect --source . --verbose

if ! command -v osv-scanner >/dev/null 2>&1; then
  echo "❌ osv-scanner not installed. Install via: brew install osv-scanner" >&2
  exit 1
fi
osv-scanner --lockfile bun.lock

echo "✅ Pre-push checks passed"
